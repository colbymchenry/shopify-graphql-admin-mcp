{
  "name": "shopify-graphql-admin-mcp",
  "version": "1.0.0",
  "description": "MCP server providing full access to Shopify's Admin GraphQL API with schema introspection",
  "type": "module",
  "bin": {
    "shopify-graphql-admin-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "mcp",
    "shopify",
    "graphql",
    "admin-api",
    "model-context-protocol",
    "metaobjects",
    "metafields"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/colbymchenry/shopify-graphql-admin-mcp.git"
  }
}
